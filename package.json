{
  "name": "mwell-intra",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:intra-live": "node scripts/qa/full-intra-live-e2e.mjs",
    "test:intra-live-contract": "node --test scripts/qa/live-e2e-contract.test.mjs",
    "test:environment-guard": "node --test scripts/lib/target-environment.test.mjs",
    "test:warehouse-w1": "pnpm --filter @intra/shell exec playwright test tests/e2e/warehouse-w1-workflows.spec.ts",
    "test:warehouse-w1:visual": "pnpm --filter @intra/shell exec playwright test tests/e2e/warehouse-w1-visual.spec.ts",
    "test:warehouse-w1:live": "pnpm --filter @intra/shell run test:e2e:live",
    "test:warehouse-w1:performance": "pnpm --filter @intra/shell exec playwright test tests/e2e/warehouse-w1-performance.spec.ts",
    "report:warehouse-w1:visual": "node scripts/qa/build-warehouse-contact-sheet.mjs",
    "provision:test:warehouse-w1": "pnpm provision:test:uat",
    "provision:test:uat": "node scripts/qa/provision-uat-intra-test-users.mjs",
    "test:provision:uat": "node --test scripts/qa/provision-uat-intra-test-users.test.mjs",
    "verify:procurement-contract": "node scripts/verify-effective-procurement-contract.mjs",
    "verify:advisor-hardening": "node scripts/verify-current-function-advisor-hardening.mjs",
    "verify:policy-alignment-schema": "node scripts/verify-policy-alignment-schema.mjs",
    "verify:warehouse-w1-schema": "node scripts/verify-warehouse-w1-schema.mjs",
    "verify:warehouse-w1-contract": "node scripts/verify-warehouse-w1-contract.mjs",
    "verify:cross-department-wms": "node --test scripts/verify-cross-department-wms.test.mjs",
    "verify:insights-read-only": "node --test scripts/verify-insights-read-only.test.mjs",
    "verify:launch-artifacts": "node scripts/verify-launch-artifacts.mjs",
    "verify:supabase-advisors": "node scripts/qa/snapshot-supabase-advisors.mjs",
    "verify:knowledge-base": "node scripts/verify-knowledge-base.mjs",
    "verify:knowledge-evidence-catalog": "node scripts/qa/knowledge-evidence-catalog.mjs",
    "verify:supabase-cutover": "node scripts/verify-supabase-cutover.mjs",
    "test:organization-contract": "node --test scripts/verify-organization-contract.test.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
