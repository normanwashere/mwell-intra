# Target identity for live QA:
# - production: read-only smoke runs against the production project.
# - uat: governed mutation runs against the dedicated UAT project.
# - local: local app runs backed by a dedicated non-production Supabase project.
APP_ENV=

# Exact project ref parsed from NEXT_PUBLIC_SUPABASE_URL for this target.
SUPABASE_PROJECT_REF=

# Production project ref used as the mutation deny-list. Required for mutations.
PRODUCTION_SUPABASE_PROJECT_REF=

# Supabase target URL. Live runners accept exact <project-ref>.supabase.co hosts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Mutation runs require both values to be explicitly set to true.
AUDIT_MUTATIONS=
POLICY_ALLOW_TEST_MUTATIONS=

# Optional server-only Vercel deployment protection bypass for live QA probes.
VERCEL_AUTOMATION_BYPASS_SECRET=

APP_URL=http://127.0.0.1:3000
# Data source for the warehouse module: supabase | memory (auto-detect if unset)
NEXT_PUBLIC_DATA_SOURCE=
NEXT_PUBLIC_ENABLE_SW=true
