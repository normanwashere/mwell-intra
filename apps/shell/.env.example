# Shell env (spec §9). Leave BLANK to run in memory/demo mode — the app builds
# and runs with no live backend. Set both to enable the live Supabase JWT
# contract (single M-Intra project for now).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Force the shell to use the in-memory demo/auth contract even when Supabase
# vars are present. Used by smoke tests and non-live previews.
NEXT_PUBLIC_DATA_SOURCE=
