{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@intra/config/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@shell/*": ["./*"],
      "@/*": ["../../modules/warehouse/src/*"]
    },
    "plugins": [{ "name": "next" }],
    "lib": ["dom", "dom.iterable", "esnext", "webworker"]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
