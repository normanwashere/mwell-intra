{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@intra/config/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@shell/*": ["./*"],
      "@warehouse/*": ["../../modules/warehouse/src/*"],
      "@/*": ["../../modules/warehouse/src/*"]
    },
    "plugins": [{ "name": "next" }],
    "lib": ["dom", "dom.iterable", "esnext", "webworker"]
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "proxy.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "tests/**",
    "playwright.config.ts"
  ]
}
